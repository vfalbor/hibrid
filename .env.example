# --- hibrid: configuración ---
HIBRID_HOST=0.0.0.0
HIBRID_PORT=8095

# Runtimes locales (OpenAI-compatibles), en orden de preferencia.
# Ollama=11434, llama.cpp server=8080, LM Studio=1234
HIBRID_LOCAL_ENDPOINTS=http://localhost:11434/v1,http://localhost:8080/v1,http://localhost:1234/v1

# Claves de nube (definen a qué modelos remotos tiene acceso el usuario).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Modelos de nube barato/potente.
HIBRID_CLOUD_CHEAP=claude-haiku-4-5-20251001
HIBRID_CLOUD_STRONG=claude-opus-4-8

# Pesos de la función de utilidad U(d) (perillas por defecto).
HIBRID_LAMBDA_COST=1.0
HIBRID_LAMBDA_LAT=0.3
HIBRID_LAMBDA_PRIV=2.0

# Gate de escalado y velocidad mínima local.
HIBRID_ESCALATION_CONF=0.55
HIBRID_MIN_LOCAL_TPS=8.0

# Privacidad: si hay PII, fuerza ejecución local (no sale el dato).
HIBRID_PII_LOCAL=true
